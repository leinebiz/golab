# ============================================================
# GoLab Environment Variables
# Copy to .env.local and fill in your values
# ============================================================

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://golab:golab_dev@localhost:5432/golab_dev

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Object Storage (MinIO / S3) ─────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=golab-dev
S3_REGION=us-east-1

# ── Auth (NextAuth.js v5) ───────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-to-a-random-secret-in-production

# OAuth Providers (optional for local dev — credentials auth works without these)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# ── Stripe (Payment Processing) ─────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Twilio (WhatsApp Notifications) ─────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=+14155238886

# ── Resend (Email) ──────────────────────────────────────────
RESEND_API_KEY=re_...

# ── Courier Integration ─────────────────────────────────────
COURIER_API_URL=http://localhost:3003/api
COURIER_API_KEY=dev-courier-key
COURIER_WEBHOOK_SECRET=dev-webhook-secret

# ── AI / RAG (Anthropic Claude) ─────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Observability ────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=golab-portal
LOG_LEVEL=info

# ── Application ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_VERSION=0.0.1
NODE_ENV=development
