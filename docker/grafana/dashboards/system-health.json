{
  "dashboard": {
    "title": "GoLab - System Health",
    "uid": "golab-system-health",
    "tags": ["golab"],
    "timezone": "browser",
    "refresh": "30s",
    "panels": [
      {
        "title": "API Request Rate",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
        "targets": [
          {
            "expr": "rate(golab_api_request_duration_ms_count[5m])",
            "legendFormat": "{{method}} {{path}}"
          }
        ]
      },
      {
        "title": "API Latency (p50 / p95 / p99)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
        "targets": [
          {
            "expr": "histogram_quantile(0.50, rate(golab_api_request_duration_ms_bucket[5m]))",
            "legendFormat": "p50"
          },
          {
            "expr": "histogram_quantile(0.95, rate(golab_api_request_duration_ms_bucket[5m]))",
            "legendFormat": "p95"
          },
          {
            "expr": "histogram_quantile(0.99, rate(golab_api_request_duration_ms_bucket[5m]))",
            "legendFormat": "p99"
          }
        ]
      },
      {
        "title": "HTTP Error Rate (5xx)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
        "targets": [
          {
            "expr": "rate(golab_api_request_duration_ms_count{http_status_code=~\"5..\"}[5m])",
            "legendFormat": "5xx errors/s"
          }
        ]
      },
      {
        "title": "Active Requests",
        "type": "stat",
        "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 },
        "targets": [
          {
            "expr": "golab_requests_active",
            "legendFormat": "active"
          }
        ]
      },
      {
        "title": "OTel Collector - Spans Exported",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 6, "x": 18, "y": 8 },
        "targets": [
          {
            "expr": "rate(otelcol_exporter_sent_spans_total[5m])",
            "legendFormat": "spans/s"
          }
        ]
      },
      {
        "title": "Notification Delivery Rate",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
        "targets": [
          {
            "expr": "rate(golab_notifications_sent_total[5m]) * 60",
            "legendFormat": "notifications/min"
          }
        ]
      },
      {
        "title": "Review Queue Depth",
        "type": "gauge",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
        "targets": [
          {
            "expr": "golab_review_queue_depth",
            "legendFormat": "queue depth"
          }
        ]
      }
    ]
  }
}
